<script>
const overlay=document.getElementById('overlay');function show(){overlay.style.display='block';document.body.style.overflow='hidden';}function hide(){overlay.style.display='none';document.body.style.overflow='';}
function closeAll(){document.querySelectorAll('.window').forEach(w=>w.remove());hide();}overlay.addEventListener('click',closeAll);document.addEventListener('keydown',e=>{if(e.key==='Escape')closeAll();});
function createWindow(title,html){closeAll();show();const w=document.createElement('div');w.className='window';w.innerHTML=`<div class="window-header">${title}<span class="close" onclick="closeAll()">✖</span></div><div class="window-body">${html}</div>`;document.body.appendChild(w);} const S={
eczema:['Assess severity and infection features.','Optimise emollients and steroid potency by site/severity.','Address adherence barriers and trigger control.','Escalate if widespread, infected, or poor response.'],
cellulitis:['Warm, tender spreading erythema with systemic review.','Mark margins and review progression timeframe.','Use oral/IV pathway according to severity.','Urgent escalation for sepsis/rapid deterioration.'],
contact:['Identify likely irritant or allergen exposure.','Avoidance and barrier skin-care plan.','Topical anti-inflammatory therapy in flare.','Consider patch testing for recurrent cases.'],
urticaria:['Transient weals ± angioedema assessment.','Non-sedating antihistamine first line.','Review triggers incl. meds, infection, stress.','Emergency route for airway or breathing compromise.'],
shingles:['Dermatomal unilateral painful vesicular rash.','Antiviral timing and analgesia plan.','Urgent same-day eye referral if ophthalmic involvement.'],
lesion:['Assess ABCDE and change over time.','Document lesion details clearly and consistently.','Use urgent suspected-cancer referral pathway when indicated.']};
function openWindow(k){const items=S[k]||[];createWindow('Skin guidance',`<div class="section"><h4>Approach</h4><ul>${items.map(i=>`<li>${i}</li>`).join('')}</ul></div><div class="section alt"><h4>Note</h4><ul><li>Use local/NICE pathways for treatment specifics and referral criteria.</li></ul></div>`)}
</script>
</body>
